# AppFitness API — environment template (no real values here; copy to .env)

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
# 3001 by default so the legacy Express MVP (port 3000) can run alongside
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (live connection deferred until approved —
# schema validation/generation work with a placeholder value)
DATABASE_URL="postgresql://user:password@localhost:5432/appfitness_dev"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Access-token signing secret, min 32 chars. Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Refresh tokens are opaque random values stored hashed — no second secret needed.
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Medical field encryption (ADR-P006) ─────────────────────────────────────
# AES-256-GCM key for medical free-text at rest. Base64, exactly 32 bytes.
# Required in production (boot fails without it). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MEDICAL_ENC_KEY=
MEDICAL_ENC_KEY_ID=k1
