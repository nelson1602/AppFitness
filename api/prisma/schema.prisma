  deletedBy String?   @map("deleted_by") @db.Uuid
  syncSeq   BigInt    @default(0) @map("sync_seq")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_recommendations_user")

  @@index([userId, createdAt], map: "idx_recommendations_user_created")
  @@index([userId, syncSeq], map: "idx_recommendations_user_syncseq")
  @@map("recommendations")
}

