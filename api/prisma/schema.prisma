model Recommendation {
  id              String                 @id @default(uuid()) @db.Uuid
  userId          String                 @map("user_id") @db.Uuid
  type            String
  priority        RecommendationPriority @default(MEDIUM)
  title           String
  body            String
  ruleVersion     String                 @map("rule_version") // explainability: which rule version produced this
  inputs          Json                   @default("{}") // explainability: inputs the rule consumed
  actionData      Json                   @default("{}") @map("action_data")
  scientificBasis String?                @map("scientific_basis")
  confidence      Float?
  isRead          Boolean                @default(false) @map("is_read")
  isApplied       Boolean                @default(false) @map("is_applied")
  validUntil      DateTime?              @map("valid_until") @db.Date

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  version   Int       @default(1)
