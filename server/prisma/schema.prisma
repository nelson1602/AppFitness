generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  phone        String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens     RefreshToken[]
  routines          Routine[]
  workoutLogs       WorkoutLog[]
  nutritionLogs     NutritionLog[]
  bodyWeights       BodyWeight[]
  bodyMeasurements  BodyMeasurement[]
  profile           UserProfile?
  healthLogs        HealthLog[]
  recommendations   Recommendation[]
  notifications     Notification[]
  achievements      UserAchievement[]
  stats             UserStats?
  progressSnapshots ProgressSnapshot[]
  coachInsights     CoachInsight[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Workouts ────────────────────────────────────────────────────────────────

model Exercise {
  id           String  @id @default(cuid())
  name         String  @unique
  muscleGroup  String
  category     String  // strength | cardio | flexibility | bodyweight
  instructions String?

  routineExercises RoutineExercise[]
  workoutSets      WorkoutSet[]
}

model Routine {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exercises   RoutineExercise[]
  workoutLogs WorkoutLog[]

  @@index([userId])
}

model RoutineExercise {
  id           String  @id @default(cuid())
  order        Int
  targetSets   Int?
  targetReps   Int?
  targetWeight Float?

  routineId  String
  exerciseId String
  routine    Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([routineId, order])
  @@index([routineId])
}

model WorkoutLog {
  id         String    @id @default(cuid())
  name       String
  notes      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  userId    String
  routineId String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine   Routine? @relation(fields: [routineId], references: [id], onDelete: SetNull)

  sets WorkoutSet[]

  @@index([userId, startedAt])
}

model WorkoutSet {
  id        String  @id @default(cuid())
  setNumber Int
  reps      Int?
  weight    Float?  // kg
  rpe       Float?  // 1–10
  completed Boolean @default(false)
  notes     String?

  workoutLogId String
  exerciseId   String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])

  @@index([workoutLogId])
}

// ─── Nutrition ───────────────────────────────────────────────────────────────

model Food {
  id        String  @id @default(cuid())
  name      String  @unique
  brand     String?
  // macros per 100 g
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  fiber     Float?

  mealItems MealItem[]
}

model NutritionLog {
  id        String   @id @default(cuid())
  // stored as ISO date string "YYYY-MM-DD" for SQLite compatibility
  date      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  meals Meal[]

  @@unique([userId, date])
  @@index([userId])
}

model Meal {
  id    String @id @default(cuid())
  name  String // Breakfast | Lunch | Dinner | Snack
  order Int    @default(0)

  nutritionLogId String
  nutritionLog   NutritionLog @relation(fields: [nutritionLogId], references: [id], onDelete: Cascade)

  items MealItem[]

  @@index([nutritionLogId])
}

model MealItem {
  id       String @id @default(cuid())
  quantity Float  // grams

  mealId String
  foodId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food   Food   @relation(fields: [foodId], references: [id])

  @@index([mealId])
}

// ─── Progress ────────────────────────────────────────────────────────────────

model BodyWeight {
  id        String   @id @default(cuid())
  weight    Float    // kg
  date      String   // "YYYY-MM-DD"
  notes     String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model BodyMeasurement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       String   // "YYYY-MM-DD"

  bodyFatPct Float?   // %
  waistCm    Float?
  hipCm      Float?
  chestCm    Float?
  leftArmCm  Float?
  rightArmCm Float?
  neckCm     Float?
  notes      String?

  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Engines ─────────────────────────────────────────────────────────────────

model UserProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  birthDate           String?
  gender              String?
  heightCm            Float?

  primaryGoal         String   @default("maintain")
  targetWeightKg      Float?
  targetDate          String?

  fitnessLevel        String   @default("intermediate")
  yearsTraining       Float    @default(0)

  activityLevel       String   @default("moderate")
  occupation          String?
  sleepHours          Float    @default(7)
  stressLevel         Int      @default(3)

  equipment           String   @default("[]")

  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  injuries               String?

  trainingDaysPerWeek Int      @default(3)
  sessionDurationMins Int      @default(60)

  targetCalories      Int?
  targetProteinG      Float?
  targetCarbsG        Float?
  targetFatG          Float?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HealthLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           String

  sleepHours     Float?
  sleepQuality   Int?
  energyLevel    Int?
  stressLevel    Int?
  restingHR      Int?
  mood           Int?
  readinessScore Float?
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String
  priority   String   @default("medium")
  title      String
  body       String
  actionData String   @default("{}")
  isRead     Boolean  @default(false)
  isApplied  Boolean  @default(false)
  validUntil String?

  createdAt  DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String
  title     String
  message   String
  data      String   @default("{}")
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  icon        String
  category    String
  xpReward    Int      @default(50)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt    DateTime @default(now())
  notified      Boolean  @default(false)

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserStats {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  xp               Int      @default(0)
  level            Int      @default(1)
  totalXp          Int      @default(0)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate String?

  workoutsLogged   Int      @default(0)
  mealsLogged      Int      @default(0)
  weightsLogged    Int      @default(0)
  prsSet           Int      @default(0)
}

model ProgressSnapshot {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart     String

  avgWeightKg   Float?
  totalVolumeKg Float?
  avgCalories   Float?
  workoutCount  Int      @default(0)
  isDeloadWeek  Boolean  @default(false)

  createdAt     DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId])
}

model CoachInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart   String
  summary     String
  insights    String   @default("[]")
  adjustments String   @default("{}")

  createdAt   DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId])
}
