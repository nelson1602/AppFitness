# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL where the client is hosted (used for CORS and email links).
# In production with same-origin serving, set this to your public domain.
CLIENT_URL=https://yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path — relative to the server working directory
DATABASE_URL="file:./prod.db"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a random generator:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_char_secret_1
JWT_REFRESH_SECRET=replace_with_random_64_char_secret_2
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SMTP (optional — emails are silently skipped if not set) ─────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=AppFitness <noreply@yourdomain.com>
